{
  "name": "@superclaw-ai/cli",
  "version": "0.1.0",
  "description": "SuperClaw CLI — build your digital workforce",
  "type": "module",
  "bin": {
    "superclaw": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "dependencies": {
    "@superclaw-ai/core": "workspace:*",
    "@superclaw-ai/types": "workspace:*",
    "@superclaw-ai/channel-discord": "workspace:*",
    "@superclaw-ai/channel-cli": "workspace:*",
    "cac": "^6.7.14",
    "picocolors": "^1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperSupeng/SuperClaw.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/SuperSupeng/SuperClaw",
  "license": "Apache-2.0",
  "keywords": ["ai", "agent", "multi-agent", "digital-workforce", "superclaw"]
}
