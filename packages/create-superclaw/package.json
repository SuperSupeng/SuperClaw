{
  "name": "create-superclaw",
  "version": "0.1.1",
  "description": "Scaffold a new SuperClaw project",
  "type": "module",
  "bin": {
    "create-superclaw": "./dist/index.js"
  },
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
