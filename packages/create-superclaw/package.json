    "@clack/prompts": "^0.10.0",
    "picocolors": "^1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperSupeng/SuperClaw.git",
    "directory": "packages/create-superclaw"
  },
  "homepage": "https://github.com/SuperSupeng/SuperClaw",
